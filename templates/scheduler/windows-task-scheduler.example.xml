<?xml version="1.0" encoding="UTF-16"?>
<!--
  Windows Task Scheduler recipe for the daily kickoff.

  Import with:
    schtasks /Create /TN "ContentEngineKickoff" /XML windows-task-scheduler.example.xml
  Or open Task Scheduler > Import Task... and select this file.

  Replace before importing:
    <CONTENT_HOME>  absolute path to your instance directory
    <NODE_BIN>      absolute path to node.exe (e.g. C:\Program Files\nodejs\node.exe)
    <ENGINE_DIR>    absolute path to this checkout
    StartBoundary   the daily run time (local time)

  CONTENT_HOME is supplied to the process via the cmd.exe `set` prefix in Arguments
  (the §4.1 placement rule — it is NOT read from $CONTENT_HOME/.env).

  ==========================================================================
  OPTIONAL extra triggers — the trend pass + the monthly jobs. This XML imports
  the DAILY KICKOFF; create the others with `schtasks` one-liners (no extra XML
  needed). Run each only when you enable its pathway in config/system.json.
  Replace <CONTENT_HOME>, <NODE_BIN>, <ENGINE_DIR>, <brand-id>.

  Trend pass (config-gated: trends.enabled; §8.8) — HOURLY (1h); use /SC DAILY /ST 09:00
  for a 24h pass, or /SC HOURLY /MO 4 for a 4h cadence. For the apify adapter set the
  confirmed trends.tracked_accounts + trends.keywords first.
    schtasks /Create /TN "ContentEngineTrendPoll" /SC HOURLY /TR "cmd /c set \"CONTENT_HOME=<CONTENT_HOME>\" && \"<NODE_BIN>\" \"<ENGINE_DIR>\bin\engine.js\" poll-trends >> \"<CONTENT_HOME>\logs\trend-poll.task.log\" 2>&1"

  Monthly competitor scan (config-gated: competitor_scan.enabled; roadmap #5) — 1st @ 07:00.
  --yes confirms the DD-18 scrape gate; apply the proposal with voice-calibrate --apply --consent.
    schtasks /Create /TN "ContentEngineCompetitorScan" /SC MONTHLY /D 1 /ST 07:00 /TR "cmd /c set \"CONTENT_HOME=<CONTENT_HOME>\" && \"<NODE_BIN>\" \"<ENGINE_DIR>\bin\engine.js\" competitor-scan --brand <brand-id> --yes >> \"<CONTENT_HOME>\logs\competitor-scan.task.log\" 2>&1"

  Monthly breakout-discovery reminder (free, manual Grok) — 1st @ 08:00. Read-only: PRINTS the
  prompt to a log so the manual step never slips. Then run: engine suggest apply --file <reply> --brand <brand-id> --yes
    schtasks /Create /TN "ContentEngineBreakoutReminder" /SC MONTHLY /D 1 /ST 08:00 /TR "cmd /c set \"CONTENT_HOME=<CONTENT_HOME>\" && \"<NODE_BIN>\" \"<ENGINE_DIR>\bin\engine.js\" suggest prompt breakout >> \"<CONTENT_HOME>\logs\breakout-reminder.log\" 2>&1"
  ==========================================================================
-->
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Open Content Engine daily kickoff</Description>
  </RegistrationInfo>
  <Triggers>
    <CalendarTrigger>
      <StartBoundary>2099-01-01T08:30:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByDay>
        <DaysInterval>1</DaysInterval>
      </ScheduleByDay>
    </CalendarTrigger>
  </Triggers>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <StartWhenAvailable>true</StartWhenAvailable>
    <Enabled>true</Enabled>
  </Settings>
  <Actions>
    <Exec>
      <Command>cmd.exe</Command>
      <Arguments>/c set "CONTENT_HOME=&lt;CONTENT_HOME&gt;" &amp;&amp; "&lt;NODE_BIN&gt;" "&lt;ENGINE_DIR&gt;\bin\engine.js" kickoff &gt;&gt; "&lt;CONTENT_HOME&gt;\logs\kickoff.task.log" 2&gt;&amp;1</Arguments>
    </Exec>
  </Actions>
</Task>

# Normalize line endings: treat everything as text and auto-detect, committing LF.
* text=auto eol=lf

# Explicit text types (LF in the repo regardless of platform checkout).
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf

# Windows scheduler/batch recipes keep CRLF.
*.cmd   text eol=crlf
*.bat   text eol=crlf
*.ps1   text eol=crlf

# Fixture binary assets: never normalize or diff as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.gif   binary
*.mp4   binary
*.mov   binary

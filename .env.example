# =============================================================================
# Open Content Engine — .env.example
# =============================================================================
# The COMPLETE, normative environment-variable surface (release-spec §4; model §9 r4).
# `engine init` copies this file verbatim to $CONTENT_HOME/.env for you to fill in.
#
# How these are read (release-spec §4.4, engine/shared/secrets.js — DD-8):
#   1. process.env
#   2. $CONTENT_HOME/.env  (THIS file, once copied to your instance directory)
# Resolution TERMINATES there — no fallback into the checkout or any other path.
#
# Rules:
#   - This is the ONLY secrets location for an instance. NEVER commit your filled-in
#     copy (.gitignore denies `.env` / `*.env` and allowlists only `.env.example`).
#   - Every variable the engine reads appears below, grouped by purpose, each with its
#     class (Tier 1 secret / Tier 3 identifier / config / diagnostic), its consumer
#     (least privilege — only the named component reads it), and required vs optional.
#     You should never need to read source to learn the variable surface (model §1.1).
#   - Tier glossary (§0.4): Tier 1 = a secret value (token/key) — masked in all logs;
#     Tier 3 = a non-secret instance identifier (handle, id); config = non-secret
#     operational setting.
#   - Leave a variable BLANK or absent to mean "not set". A blank required credential
#     fails fast at startup with a named error — the engine never retries a missing
#     credential (release-spec §15.1).
#   - Mode/safety POSTURE is NOT set here. It lives in config/system.json `mode`
#     (release-spec §11). The §4.5 vars in this file are diagnostic OVERRIDES only,
#     logged loudly at startup when set — never your durable safety setting.


# -----------------------------------------------------------------------------
# 1. CORE  (release-spec §4.1 — always read)
# -----------------------------------------------------------------------------
#
# CONTENT_HOME  [config, REQUIRED]  — consumer: engine/shared/paths.js only (RD-3).
#   The absolute path to your instance directory. The engine locates ALL mutable
#   state (queue, brands, config, logs, and THIS .env) under it; there is no fallback.
#
#   *** CONTENT_HOME is intentionally NOT set in this file. ***
#   It is the one variable that CANNOT live in $CONTENT_HOME/.env, because paths.js
#   needs it to FIND this file. Set it in your PROCESS environment instead — your
#   shell profile, a service definition, or your scheduler recipe (every
#   templates/scheduler/ recipe sets it). Examples (do NOT uncomment here):
#     export CONTENT_HOME="$HOME/content-instance"          # bash/zsh profile
#     setx CONTENT_HOME "C:\path\to\content-instance"       # Windows (persisted)
#     $env:CONTENT_HOME = "C:\path\to\content-instance"     # PowerShell (session)
#   The only commands that run WITHOUT it are `engine init --home <path>` and
#   `engine fixture-run` (release-spec §4.1).

# Discord approval delivery is handled by the host runtime's Discord connector/permissions.
# This engine does not require a Discord bot token in $CONTENT_HOME/.env. Bind channel ids in
# config/system.json and make sure the host runtime can post/read/react in those channels.


# -----------------------------------------------------------------------------
# 2. PUBLISHER CREDENTIALS  (release-spec §4.2 — per platform tier, RD-7 / RD-11)
# -----------------------------------------------------------------------------
# Each platform-direct credential is read ONLY inside its registered publisher
# adapter (the §12.3 seam, RD-11); no other component may read them. Publisher
# integration is deferrable until you flip to LIVE — SAFE / LIVE_PREVIEW do not need
# these.

# --- Postiz backend (Twitter/X, Instagram, Facebook, YouTube — the multi-platform lane)
# POSTIZ_API_KEY  [Tier 1 secret, REQUIRED for any Postiz-backed platform]
#   Consumer: the postiz publisher adapter + the analytics pull (model §9 publishing
#   tool row). Set BOTH POSTIZ_API_KEY and POSTIZ_API_URL together, or neither —
#   setup C1 flags a half-configured pair.
POSTIZ_API_KEY=
# POSTIZ_API_URL  [config, REQUIRED with the key]  — your Postiz instance base URL.
#   Consumer: same as above.
POSTIZ_API_URL=

# --- Giphy direct lane (the platform-direct publisher adapter)
# GIPHY_API_KEY  [Tier 1 secret, REQUIRED only for the Giphy lane]
#   Consumer: the giphy publisher adapter ONLY (platform-direct row, RD-11).
GIPHY_API_KEY=
# GIPHY_USERNAME  [Tier 3 identifier, REQUIRED only for the Giphy lane]
#   Consumer: the giphy publisher adapter ONLY. The Giphy channel/username the upload
#   is attributed to (any leading @ is stripped). Not a secret.
GIPHY_USERNAME=


# -----------------------------------------------------------------------------
# 3. PROVIDER KEYS  (release-spec §4.3 — OPTIONAL features only)
# -----------------------------------------------------------------------------
# All OPTIONAL. Set a key ONLY if you configure an engine-side component to call that
# provider directly. The visual gate resolves whichever ONE of these you name in the
# config/system.json §12.5 provider block (`endpoint_env`) via the §4.4 resolver — so
# any key here is consumed by NAME, only by the component you point at it. Each is also
# a Tier 1 secret recognized by the write-time log redactor (engine/shared/redact.js),
# so its value is masked everywhere it could otherwise appear in logs.
#
# NOTE: the AI CHAIN's own model access belongs to your HOST RUNTIME/subscription plan
# (RD-2), NOT here — the engine never proxies general LLM provider keys. These are only
# for OPTIONAL engine-side external services.

# APIFY_API_KEY  [Tier 1 secret, optional]  — scraper / trend / corpus-intake adapter.
APIFY_API_KEY=
# XAI_API_KEY  [Tier 1 secret, optional]  — trend/research adapter.
XAI_API_KEY=


# -----------------------------------------------------------------------------
# 4. MODE / DIAGNOSTIC OVERRIDES  (release-spec §4.5 — OPTIONAL, LOUD when set)
# -----------------------------------------------------------------------------
# All OPTIONAL and all DIAGNOSTIC. Safety posture lives in config/system.json `mode`
# (§11), not here. Each variable below has a shipped in-tree consumer, is logged loudly
# at startup when set, and is meant for testing / one-off runs — do NOT use them as your
# durable configuration. Set a flag to `1` to enable; unset (or any other value) is off.
# Leave these BLANK in normal operation.

# --- Mode override
# ENGINE_MODE  — pin the run mode for one invocation: SAFE | LIVE_PREVIEW | LIVE.
#   Precedence (engine/orchestrator/mode.js): explicit --mode > ENGINE_MODE > config.mode
#   > SAFE. An unknown value falls CLOSED to SAFE. Reported as the source so it logs loudly.
ENGINE_MODE=

# --- Test / dry-run toggles
# ENGINE_TEST_MODE  — set to 1 to mark this a test run. The publisher adapters and the
#   executor REFUSE any real publish while it is 1 (fail-closed test guard); the pre-gate
#   lint annotates its result. Use the fixture-run harness for end-to-end test instead.
ENGINE_TEST_MODE=
# ANALYTICS_DRY_RUN  — set to 1 so the engagement collector produces synthetic metrics
#   and makes NO platform/adapter call.
ANALYTICS_DRY_RUN=
# REACTION_LISTENER_DRY_RUN  — set to 1 so the approval reaction listener records the
#   decision in the ledger but writes NO queue entry and sends nothing on the surface.
REACTION_LISTENER_DRY_RUN=
# REACTION_LISTENER_DEBUG  — set to 1 for verbose approval-surface adapter logging.
REACTION_LISTENER_DEBUG=
# CALENDAR_DRY_RUN  — set to 1 so the optional calendar tick selects + logs slots but
#   writes no records and no state (no dispatch).
CALENDAR_DRY_RUN=
# WORKFLOW_LEDGER_DISABLE  — set to 1 to turn workflow-ledger recording into a no-op
#   (the ledger is best-effort observability; disabling it removes that signal only).
WORKFLOW_LEDGER_DISABLE=
# RETRY_GATES_FAILED  — set to 1 to let the executor re-admit a slot whose gates failed
#   on a previous run. Never re-admits an interrupted_hold entry (crash-safety invariant).
RETRY_GATES_FAILED=

# --- Publish-posture overrides (the two-opt-in live gates — both must be set for live)
# POSTIZ_DRAFT_ONLY  — defaults to ON. The Postiz adapter creates DRAFTS unless this is
#   explicitly set to 0 AND POSTIZ_AUTO_PUBLISH_ALLOWED=1 (the two-opt-in auto-publish gate).
POSTIZ_DRAFT_ONLY=
# POSTIZ_AUTO_PUBLISH_ALLOWED  — set to 1 (together with POSTIZ_DRAFT_ONLY=0) to permit
#   auto-publish on a Postiz lane. One opt-in alone is never enough (fail-closed).
POSTIZ_AUTO_PUBLISH_ALLOWED=
# GIPHY_UPLOAD_LIVE  — set to 1 to actually attempt a Giphy upload (else handoff is a
#   dry-run that validates and returns with no network call).
GIPHY_UPLOAD_LIVE=
# GIPHY_APPROVED_LIVE  — set to 1 to record that the reviewer approved this upload.
#   A live Giphy upload requires BOTH GIPHY_UPLOAD_LIVE=1 and GIPHY_APPROVED_LIVE=1
#   (fail-closed: the first alone is BLOCKED, never silently promoted).
GIPHY_APPROVED_LIVE=

# --- Run targeting (point a single run at one content id)
# CONTENT_ID / TARGET_CONTENT_ID  — restrict the executor to one content id
#   (TARGET_CONTENT_ID takes precedence over CONTENT_ID when both are set).
CONTENT_ID=
TARGET_CONTENT_ID=

# --- Output override
# VISUAL_CHECK_OUT_DIR  — override the directory the visual gate writes its durable
#   verdict JSON to (else the §1.2 location under $CONTENT_HOME).
VISUAL_CHECK_OUT_DIR=


# -----------------------------------------------------------------------------
# 5. CI / HYGIENE  (continuous-integration only — never an instance secret)
# -----------------------------------------------------------------------------
# ENGINE_BRAND_DENYLIST  [config, optional — CI/maintainer only]
#   Comma-separated list of brand/codename terms the hygiene leak scan must never find
#   in the tree (consumer: the brand-leak self-check / CI hygiene job). It holds NO
#   secret values — only terms to forbid — and is supplied by the CI environment, not by
#   an operator instance. Per RD-12, CI carries ZERO real secrets and runs no live-API
#   tier; leave this UNSET for a normal install.
# ENGINE_BRAND_DENYLIST=term-one,term-two
